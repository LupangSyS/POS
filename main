    <script>
        let analysisData = {};
        let selectedFormat = 'individual';

        function selectFormat(format) {
            selectedFormat = format;
            document.getElementById('fmt1').checked = format === 'individual';
            document.getElementById('fmt2').checked = format === 'grouped';
            document.getElementById('fmt3').checked = format === 'settlement';
        }

        async function analyzeInput() {
            const textInput = document.getElementById('dataInput').value.trim();
            const imageFile = document.getElementById('imageInput').files[0];

            if (!textInput && !imageFile) {
                alert('กรุณากรอกข้อมูลหรืออัปโหลดรูปภาพ');
                return;
            }

            showLoading(true);
            
            try {
                let inputText = textInput;

                if (imageFile) {
                    inputText = await extractTextFromImage(imageFile);
                }

                const apiKey = prompt('กรุณากรอก Google Gemini API Key:\n(https://aistudio.google.com/apikey)');
                if (!apiKey) {
                    showLoading(false);
                    return;
                }

                const response = await analyzeWithGemini(inputText, apiKey);
                analysisData = response;

                if (response.needsClarification && response.questions.length > 0) {
                    showClarifications(response.questions);
                } else {
                    showOutputFormatSelection();
                }
            } catch (error) {
                console.error('Error:', error);
                alert('เกิดข้อผิดพลาด: ' + error.message);
            } finally {
                showLoading(false);
            }
        }

        async function extractTextFromImage(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = async (e) => {
                    const base64 = e.target.result.split(',')[1];
                    const apiKey = document.querySelector('[data-api-key]')?.dataset.apiKey || 
                                  prompt('Google Gemini API Key:');
                    
                    try {
                        const response = await fetch('https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=' + apiKey, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                contents: [{
                                    parts: [
                                        { text: 'Extract all text from this image. Return only the text content without any explanation.' },
                                        { inlineData: { mimeType: 'image/jpeg', data: base64 } }
                                    ]
                                }]
                            })
                        });
                        
                        const data = await response.json();
                        const text = data.candidates[0].content.parts[0].text;
                        resolve(text);
                    } catch (error) {
                        reject(error);
                    }
                };
                reader.readAsDataURL(file);
            });
        }

        async function analyzeWithGemini(inputText, apiKey) {
            const prompt = `Analyze this badminton court expense data and extract the following information:

Input data:
${inputText}

Please analyze and return a JSON response with:
{
  "players": [
    {"name": "string", "courts": number|null, "minutes": number|null, "shuttles": number|null}
  ],
  "totalCosts": {
    "courtRental": number|null,
    "shuttles": number|null,
    "other": number|null,
    "total": number|null
  },
  "needsClarification": boolean,
  "questions": [
    {"field": "string", "question": "string", "affectedPlayers": ["string"]}
  ],
  "completenessScore": number (0-100),
  "notes": ["string"]
}`;

            const response = await fetch('https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=' + apiKey, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    contents: [{
                        parts: [{ text: prompt }]
                    }]
                })
            });

            const data = await response.json();
            const responseText = data.candidates[0].content.parts[0].text;
            const jsonMatch = responseText.match(/\{[\s\S]*\}/);
            
            if (jsonMatch) {
                return JSON.parse(jsonMatch[0]);
            }
            
            throw new Error('Failed to parse response');
        }

        function showClarifications(questions) {
            const section = document.getElementById('clarificationSection');
            const content = document.getElementById('clarificationContent');
            
            content.innerHTML = questions.map((q, i) => `
                <div class="clarification-box">
                    <h3>${q.question}</h3>
                    <p><small>ผู้เล่นที่เกี่ยวข้อง: ${q.affectedPlayers.join(', ')}</small></p>
                    <input type="text" id="clarification_${i}" placeholder="ตอบ..." style="margin-top: 0.5rem;">
                </div>
            `).join('');
            
            section.style.display = 'block';
            document.querySelector('html').scrollIntoView({ behavior: 'smooth' });
        }

        function hideClariifications() {
            document.getElementById('clarificationSection').style.display = 'none';
        }

        async function submitClarifications() {
            const answers = {};
            document.querySelectorAll('[id^="clarification_"]').forEach(el => {
                const index = el.id.split('_')[1];
                if (analysisData.questions[index]) {
                    answers[analysisData.questions[index].field] = el.value;
                }
            });

            // In a real implementation, merge answers with analysisData
            analysisData.clarificationAnswers = answers;
            hideClariifications();
            showOutputFormatSelection();
        }

        function showOutputFormatSelection() {
            document.getElementById('outputFormatSection').style.display = 'block';
            document.querySelector('html').scrollIntoView({ behavior: 'smooth' });
        }

        async function calculateExpenses() {
            const players = analysisData.players || [];
            const totalCost = analysisData.totalCosts?.total || 0;

            if (!totalCost || players.length === 0) {
                alert('ข้อมูลไม่เพียงพอสำหรับการคำนวณ');
                return;
            }

            let resultHTML = '';

            if (selectedFormat === 'individual') {
                resultHTML = calculateIndividual(players, totalCost);
            } else if (selectedFormat === 'grouped') {
                resultHTML = calculateGrouped(players, totalCost);
            } else if (selectedFormat === 'settlement') {
                resultHTML = calculateSettlement(players, totalCost);
            }

            document.getElementById('resultContent').innerHTML = resultHTML;
            document.getElementById('resultSection').style.display = 'block';
            document.querySelector('html').scrollIntoView({ behavior: 'smooth' });
        }

        function calculateIndividual(players, totalCost) {
            const calculations = players.map(p => {
                let share = totalCost / players.length;
               