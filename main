                <button onclick="submitClarifications()">✅ ยืนยันข้อมูล</button>
                <button class="btn-secondary" onclick="hideClariifications()">⬅️ กลับ</button>
            </div>
        </div>

        <div id="outputFormatSection" class="section" style="display: none;">
            <h2>📋 เลือกรูปแบบผลลัพธ์</h2>
            <div class="output-format">
                <div class="format-option" onclick="selectFormat('individual')">
                    <input type="radio" id="fmt1" name="format" value="individual" checked>
                    <label for="fmt1">👤 รายบุคคล<br><small>แสดงจำนวนเงินของแต่ละคน</small></label>
                </div>
                <div class="format-option" onclick="selectFormat('grouped')">
                    <input type="radio" id="fmt2" name="format" value="grouped">
                    <label for="fmt2">🔗 ก้อนรวม<br><small>รวมกลุ่มคนที่เสียเงินเท่ากัน</small></label>
                </div>
